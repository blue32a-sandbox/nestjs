{
  "name": "Node.js",
  "dockerComposeFile": ["../compose.yaml"],
  "service": "node",
  "workspaceFolder": "/opt/project",
  "postCreateCommand": "npm i -g @nestjs/cli",
  "customizations": {
    "vscode": {
      "extensions": [
        "EditorConfig.EditorConfig",
        "mhutchie.git-graph",
        "eamodio.gitlens"
      ]
    }
  }
}
